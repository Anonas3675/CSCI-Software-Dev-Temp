<!-- Specific Prompt: Can you create a basic hbs file for a wordle layout?-->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Wordle Game</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      text-align: center;
      padding: 20px;
      background-color: #f4f4f4;
    }

    h1 {
      margin-bottom: 20px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(5, 50px);
      gap: 10px;
      justify-content: center;
      margin: 20px 0;
    }

    .cell {
      width: 50px;
      height: 50px;
      border: 2px solid #000;
      font-size: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #fff;
    }

    .cell.correct {
      background-color: green;
      color: white;
    }

    .cell.present {
      background-color: yellow;
      color: white;
    }

    .cell.absent {
      background-color: gray;
      color: white;
    }

    .keyboard {
      display: grid;
      grid-template-columns: repeat(10, 40px);
      gap: 5px;
      justify-content: center;
      margin-top: 20px;
    }

    .key {
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid #000;
      background-color: #ddd;
      cursor: pointer;
    }

    .key.correct {
      background-color: green;
      color: white;
    }

    .key.present {
      background-color: yellow;
      color: white;
    }

    .key.absent {
      background-color: gray;
      color: white;
    }

    .key:active {
      transform: scale(0.95);
    }
  </style>
</head>
<body>

  <h1>Wordle Game</h1>

  <!-- Grid for guesses -->
  <div class="grid">
    {{#each guesses}}
      {{#each this}}
        <div class="cell {{#if this.class}}{{this.class}}{{/if}}">
          {{this.letter}}
        </div>
      {{/each}}
    {{/each}}
  </div>

  <!-- Keyboard -->
  <div class="keyboard">
    {{#each keys}}
      <div class="key {{#if this.class}}{{this.class}}{{/if}}">
        {{this.letter}}
      </div>
    {{/each}}
  </div>

</body>
</html>
